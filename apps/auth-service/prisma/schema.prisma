generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id            String  @id @default(cuid())
    email         String  @unique
    password      String
    name          String?
    avatar        String?
    emailVerified Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    otps     OTP[]
    sessions Session[]
}

model OTP {
    id        String   @id @default(cuid())
    email     String
    code      String
    type      OTPType
    expiresAt DateTime
    used      Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    user      User?    @relation(fields: [userId], references: [id])
    userId    String?

    @@index([email, code])
}

model Session {
    id        String   @id @default(cuid())
    userId    String
    token     String   @unique
    expiresAt DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id])
}

enum OTPType {
    VERIFY_EMAIL
    RESET_PASSWORD
}
